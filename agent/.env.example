# LiveKit Configuration (Optional - only needed for LiveKit Cloud deployment)
# Get these from https://cloud.livekit.io or your self-hosted instance
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# OpenAI Configuration (Required)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Deepgram Configuration (Required)
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key

# Model Selection (Optional)
# Choose which OpenAI model to use
LLM_CHOICE=gpt-4.1-mini

# Development Settings (Optional)
LOG_LEVEL=INFO
DEBUG_MODE=false

# Metrics Webhook (Optional)
# On call end, the agent POSTs the collected usage metrics + models used to
# this URL as JSON. Cost calculation is handled by the receiving service.
# Leave unset to skip the POST (metrics are still appended to metrics.jsonl).
METRICS_WEBHOOK_URL=https://xcoster.vercel.app/api/echo
# Optional bearer token sent as "Authorization: Bearer <token>"
METRICS_WEBHOOK_TOKEN=

# Per-company voice agent config (Optional)
# When a call's LiveKit room carries a voiceAgentId in its metadata (set by the
# aag admin panel), the worker fetches that agent's prompt/tools/voice settings
# from the aag config API. Without these, or without a voiceAgentId, the worker
# falls back to the built-in Garibook config.
#   AAG_CONFIG_BASE_URL: aag origin INCLUDING the /app basePath, e.g.
#     https://agents.ascendai.site/app
#   VOICE_AGENT_API_SECRET: shared secret, must match aag's VOICE_AGENT_API_SECRET
AAG_CONFIG_BASE_URL=
VOICE_AGENT_API_SECRET=

# Human handover webhook (Optional)
# When the `addtag` tool fires, the agent POSTs {reasonForStopping, message} here.
HANDOVER_WEBHOOK_URL=