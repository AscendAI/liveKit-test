# --- LiveKit server (used by BOTH the web server and the agent) ---
# Your self-hosted server on the VPS. Must be wss:// with valid TLS so browsers can connect.
LIVEKIT_URL=wss://your-livekit-host
# These must match the `keys:` in your VPS livekit.yaml (or your LiveKit Cloud credentials).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- Web server ---
PORT=3000

# --- Agent pipeline providers (agent only) ---
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=
