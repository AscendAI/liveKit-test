# ─── LiveKit (self-hosted) ────────────────────────────────────────────────────
# For local dev: ws://localhost:7880
# For production server: ws://YOUR_SERVER_IP:7880 or wss://your.domain.com
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ─── Soniox STT ───────────────────────────────────────────────────────────────
SONIOX_API_KEY=your-soniox-api-key

# ─── Cartesia TTS ─────────────────────────────────────────────────────────────
CARTESIA_API_KEY=your-cartesia-api-key
# Model: sonic-3 supports Bangla (bn), English (en), and more
CARTESIA_MODEL=sonic-3
# Voice ID — get from https://play.cartesia.ai
CARTESIA_VOICE=2ba861ea-7cdc-43d1-8608-4045b5a41de5
# Language code: bn for Bangla, en for English
CARTESIA_LANG=bn

# ─── LLM selection ────────────────────────────────────────────────────────────
# Supports: gpt-4.1-mini, gpt-4.1, gemini-2.0-flash, gemini-1.5-pro
LLM_CHOICE=gpt-4.1-mini

# ─── Background noise ─────────────────────────────────────────────────────────
# Path to a WAV/MP3 file to mix into TTS output (office ambience effect)
# Leave empty or remove to disable
BG_NOISE_WAV=freesound_community-office-ambience-24734.mp3
